{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "vite build --config vite.config.ts && node -e \"require('fs').cpSync('dist/public', 'public', {recursive: true})\"",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
